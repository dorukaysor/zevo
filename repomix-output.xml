    gap: 32px;
    padding: 32px 0 96px;
}

/* --- Profile Sidebar --- */
.profile-sidebar {
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px;
    text-align: center;
    height: fit-content;
}

.profile-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background-color: var(--accent);
    color: #000;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
}

.profile-sidebar h3 {
    font-size: 18px;
    margin-bottom: 4px;
}

.profile-sidebar .email {
    color: var(--muted);
    font-size: 13px;
    margin-bottom: 24px;
    display: block;
}

.profile-nav {
