<file path="css/about.css">
/* ================================================
   ZEVO — About Page Styles
   Hero, mission, values, team, CTA
   ================================================ */

/* --- About Hero --- */
.about-hero {
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    overflow: hidden;
}

.about-hero h1 {
    font-size: 64px;
}

/* --- Mission Section --- */
.mission {
    padding: 96px 0;
}

.mission-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
}

.mission-text h2 {
    margin-bottom: 24px;
}

.mission-text p {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.8;
    margin-bottom: 16px;
}

.mission-image {
    border-radius: var(--radius-lg);
    overflow: hidden;
}

.mission-image img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
}

/* --- Values Section --- */
.values {
    padding: 96px 0;
    background-color: var(--surface);
}

.values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}

.value-card {
    background-color: var(--elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 40px 32px;
}

.value-card i {
    font-size: 32px;
    color: var(--accent);
    margin-bottom: 20px;
    display: block;
}

.value-card h3 {
    font-size: 20px;
    margin-bottom: 12px;
}

.value-card p {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.7;
}

/* --- Team Section --- */
.team {
    padding: 96px 0;
}

.team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
}

.team-card {
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    text-align: center;
}

.team-card img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
}

.team-card-body {
    padding: 24px;
}

.team-card-body h3 {
    font-size: 18px;
    margin-bottom: 4px;
}

.team-card-body .role {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 12px;
    display: block;
}

.team-card-body p {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.6;
}

/* --- CTA Banner --- */
.cta-banner {
    padding: 96px 0;
    text-align: center;
    background-color: var(--surface);
}

.cta-banner h2 {
    margin-bottom: 16px;
}

.cta-banner p {
    color: var(--muted);
    margin-bottom: 32px;
    font-size: 16px;
}
</file>

<file path="css/auth.css">
/* ================================================
   ZEVO — Auth Page Styles
   Login + Register centered card
   ================================================ */

/* --- Auth Page Wrapper --- */
.auth-page {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 64px 32px;
}

/* --- Auth Card --- */
.auth-card {
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 48px;
    width: 100%;
    max-width: 440px;
}

.auth-card .auth-logo {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: 32px;
    text-align: center;
    margin-bottom: 8px;
}

.auth-card .auth-logo span {
    color: var(--accent);
}

.auth-card h2 {
    text-align: center;
    font-size: 24px;
    margin-bottom: 32px;
}

.auth-card .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
}

.auth-card .btn {
    width: 100%;
    margin-top: 8px;
}

/* --- Remember Me / Terms --- */
.remember-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
    font-size: 14px;
    color: var(--muted);
}

.remember-row input {
    accent-color: var(--accent);
    width: 16px;
    height: 16px;
}

/* --- Forgot Password --- */
.forgot-link {
    display: block;
    text-align: right;
    color: var(--muted);
    font-size: 13px;
    margin-top: -12px;
    margin-bottom: 20px;
}

.forgot-link:hover {
    color: var(--accent);
}

/* --- Auth Footer Text --- */
.auth-footer {
    text-align: center;
    margin-top: 24px;
    font-size: 14px;
    color: var(--muted);
}

.auth-footer a {
    color: var(--accent);
    font-weight: 500;
}
</file>

<file path="css/cart.css">
/* ================================================
   ZEVO — Cart Page Styles
   Cart items table + order summary
   ================================================ */

/* --- Cart Header --- */
.cart-header {
    padding: 48px 0 0;
}

.cart-header h1 {
    font-size: 36px;
}

/* --- Cart Layout --- */
.cart-layout {
    display: grid;
    grid-template-columns: 65% 35%;
    gap: 32px;
    padding: 32px 0 96px;
}

/* --- Cart Items --- */
.cart-items {
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
}

.cart-item {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 24px;
    border-bottom: 1px solid var(--border);
}

.cart-item:last-child {
    border-bottom: none;
}

.cart-item-image {
    width: 80px;
    height: 80px;
    border-radius: var(--radius);
    overflow: hidden;
    flex-shrink: 0;
}

.cart-item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.cart-item-details {
    flex: 1;
}

.cart-item-details h3 {
    font-size: 16px;
    margin-bottom: 4px;
}

.cart-item-details .muted {
    font-size: 13px;
}

.cart-item-qty {
    color: var(--muted);
    font-size: 14px;
    min-width: 60px;
    text-align: center;
}

.cart-item-price {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 16px;
    min-width: 120px;
    text-align: right;
}

/* --- Order Summary --- */
.order-summary {
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px;
    height: fit-content;
    position: sticky;
    top: 100px;
}

.order-summary h3 {
    margin-bottom: 24px;
    font-size: 20px;
}

.summary-row {
    display: flex;
    justify-content: space-between;
    padding: 12px 0;
    font-size: 14px;
    border-bottom: 1px solid var(--border);
}

.summary-row.total {
    border-bottom: none;
    padding-top: 16px;
    font-weight: 700;
    font-size: 18px;
}

.summary-row.total .amount {
    color: var(--accent);
    font-family: var(--font-heading);
}

.order-summary .btn {
    width: 100%;
    margin-top: 24px;
}
</file>

<file path="css/checkout.css">
