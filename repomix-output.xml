/* --- Wishlist Page --- */
.wishlist-header {
    padding: 48px 0 0;
}

.wishlist-header h1 {
    font-size: 36px;
}

.wishlist-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    padding: 32px 0 96px;
}
