}

.footer-bottom p {
    color: var(--muted);
    font-size: 13px;
}

/* --- Payment Badges --- */
.payment-badges {
    display: flex;
    gap: 8px;
}

.payment-badge {
    background-color: var(--elevated);
    border: 1px solid var(--border);
    padding: 4px 12px;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.02em;
}
</file>

<file path="css/home.css">
/* ================================================
   ZEVO — Homepage Styles
   Hero, categories, featured, manifesto, trust, newsletter
   ================================================ */

/* --- Hero Section --- */
.hero {
    height: calc(100vh - 112px);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
}

/* Background video */
.hero-video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
}

/* Translucent overlay screen */
.hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(10, 10, 10, 0.65);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 1;
}

/* Grid lines overlay on top of overlay/video */
.hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image:
        linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 60px 60px;
    z-index: 2;
    pointer-events: none;
}

/* yellow radial glow */
.hero-glow {
    position: absolute;
    top: -20%;
    left: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(250, 204, 21, 0.08) 0%, transparent 70%);
    z-index: 2;
    pointer-events: none;
}

.hero-content {
    position: relative;
    z-index: 3;
    max-width: 800px;
    margin: 0 auto;
    padding: 0 32px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-height: 100%;
    overflow: hidden;
}

.hero h1 {
    font-size: 76px;
    font-weight: 800;
    line-height: 1.05;
    margin-bottom: 24px;
}

.hero p {
    font-size: 18px;
    color: rgba(255, 255, 255, 0.8);
    max-width: 600px;
    margin-bottom: 40px;
    line-height: 1.7;
}

.hero-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
}

/* --- Categories Strip --- */
.categories-strip {
    padding: 96px 0;
}

.categories-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 24px;
}

.category-card {
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    text-align: center;
    transition: all 0.3s ease;
    text-decoration: none;
    color: var(--text);
    display: block;
}

.category-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
    border-color: var(--accent);
    color: var(--text);
}

.category-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
}

.category-card-body {
    padding: 20px 16px;
}

.category-card-body h3 {
    font-size: 18px;
    margin-bottom: 4px;
}

.category-card-body p {
    color: var(--muted);
    font-size: 13px;
}

/* --- Featured Products --- */
.featured {
    padding: 96px 0;
    background-color: var(--surface);
}

.products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
}

/* --- Brand Manifesto --- */
.manifesto {
    padding: 96px 0;
}

.manifesto-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
}

.manifesto-quote {
    font-family: var(--font-heading);
    font-size: 36px;
    font-weight: 700;
    font-style: italic;
    line-height: 1.3;
    color: var(--text);
}

.stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
}

.stat-box {
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px 24px;
    text-align: center;
}

.stat-box .stat-number {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 36px;
    color: var(--accent);
    margin-bottom: 8px;
}

.stat-box .stat-label {
    color: var(--muted);
    font-size: 14px;
}

/* --- Trust Badges --- */
.trust-badges {
    padding: 64px 0;
    background-color: var(--surface);
}

.badges-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    text-align: center;
}

.trust-badge {
    padding: 32px 16px;
}

.trust-badge i {
    font-size: 32px;
    color: var(--accent);
    margin-bottom: 16px;
    display: block;
}

.trust-badge h4 {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 16px;
    margin-bottom: 8px;
}

.trust-badge p {
    color: var(--muted);
    font-size: 13px;
}

/* --- Newsletter --- */
.newsletter {
    padding: 96px 0;
    text-align: center;
}

.newsletter h2 {
    margin-bottom: 16px;
}

.newsletter p {
    color: var(--muted);
    margin-bottom: 32px;
    font-size: 16px;
}

.newsletter-form {
    display: flex;
    gap: 12px;
    max-width: 500px;
    margin: 0 auto;
}

.newsletter-form input {
    flex: 1;
    padding: 14px 20px;
    background-color: var(--elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 14px;
    transition: all 0.3s ease;
}

.newsletter-form input:focus {
    outline: none;
    border-color: var(--accent);
}
</file>

<file path="css/main.css">
/* ================================================
   ZEVO — Main Stylesheet
   Reset, variables, typography, and base styles
   ================================================ */

/* --- Reset --- */
*, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* --- CSS Variables --- */
:root {
    --bg:         #0A0A0A;
    --surface:    #111111;
    --elevated:   #1A1A1A;
    --border:     rgba(255, 255, 255, 0.08);
    --text:       #F5F5F5;
    --muted:      #888888;
    --accent:     #FACC15;
    --success:    #22C55E;
    --danger:     #EF4444;

    --font-heading: 'Outfit', sans-serif;
    --font-body:    'Inter', sans-serif;
    --font-mono:    'JetBrains Mono', monospace;

    --max-width:  1280px;
    --radius:     12px;
    --radius-lg:  20px;
}

/* --- Body --- */
body {
    background-color: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
}

/* --- Typography --- */
h1 {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 64px;
    line-height: 1.1;
}

h2 {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 42px;
    line-height: 1.2;
}

h3 {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 28px;
    line-height: 1.3;
}

p {
    line-height: 1.7;
}

/* --- Links --- */
a {
    color: var(--text);
    text-decoration: none;
    transition: all 0.3s ease;
}

a:hover {
    color: var(--accent);
}

/* --- Lists --- */
ul {
    list-style: none;
}

/* --- Images --- */
img {
    max-width: 100%;
    display: block;
}

/* --- Container --- */
.container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 32px;
}

/* --- Section Title --- */
.section-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 42px;
    margin-bottom: 48px;
}

/* --- Muted Text --- */
.muted {
    color: var(--muted);
    font-size: 14px;
}

/* --- Small Label (mono uppercase) --- */
.label {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
}

/* --- Accent Color Helper --- */
.accent {
    color: var(--accent);
}

/* --- Scrollbar --- */
::-webkit-scrollbar {
    width: 8px;
}

::-webkit-scrollbar-track {
    background: var(--bg);
}

::-webkit-scrollbar-thumb {
    background: var(--elevated);
    border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
    background: #333;
}
</file>

<file path="css/nav.css">
/* ================================================
   ZEVO — Navigation Styles
   Announcement bar + main nav + dropdown
   ================================================ */

/* --- Announcement Bar --- */
.announcement-bar {
    background-color: var(--accent);
    color: #000;
    text-align: center;
    padding: 10px 16px;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.05em;
}

.announcement-bar strong {
    font-weight: 700;
}

/* --- Main Navigation --- */
.main-nav {
    position: sticky;
    top: 0;
    z-index: 1000;
    background-color: transparent;
    transition: all 0.3s ease;
}

/* frosted glass effect when scrolled */
.main-nav.scrolled {
    background: rgba(10, 10, 10, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
}

.nav-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
}
.second-nav.nav-container {
    height: 48px;
    padding: 0 32px;
    justify-content: flex-end;
}

/* --- Logo --- */
.nav-logo {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: 28px;
    color: var(--text);
    text-decoration: none;
    letter-spacing: -0.02em;
}

.nav-logo:hover {
    color: var(--text);
}

.nav-logo span {
    color: var(--accent);
}

/* --- Nav Links --- */
.nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
    list-style: none;
}

.nav-item {
    position: relative;
}

.nav-item > a {
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
    text-decoration: none;
    transition: all 0.3s ease;
    padding: 8px 0;
}

.nav-item > a:hover {
    color: var(--accent);
}

/* --- CSS-Only Dropdown --- */
.dropdown {
    position: absolute;
    top: 100%;
    left: -16px;
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 8px 0;
    min-width: 200px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: all 0.3s ease;
    margin-top: 8px;
}

.nav-item:hover .dropdown,
.dropdown-trigger:hover .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
}

.dropdown-trigger .dropdown {
    left: auto;
    right: -16px;
}

.dropdown a {
    display: block;
    padding: 10px 20px;
    font-size: 14px;
    color: var(--text);
    transition: all 0.3s ease;
}

.dropdown a:hover {
    background-color: var(--elevated);
    color: var(--accent);
}

/* --- Nav Icons --- */
.nav-icons {
    display: flex;
    align-items: center;
    gap: 20px;
}

.nav-icon {
    color: var(--text);
    font-size: 18px;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    text-decoration: none;
}

.nav-icon:hover {
    color: var(--accent);
}

/* cart item count badge */
.cart-badge {
    position: absolute;
    top: -8px;
    right: -10px;
    background-color: var(--accent);
    color: #000;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
}
</file>

<file path="css/product.css">
/* ================================================
   ZEVO — Product Detail Page Styles
   Breadcrumb, gallery, info, specs
   ================================================ */

/* --- Breadcrumb --- */
.breadcrumb {
    padding: 24px 0;
    font-size: 14px;
    color: var(--muted);
}

.breadcrumb a {
    color: var(--muted);
    transition: all 0.3s ease;
}

.breadcrumb a:hover {
    color: var(--accent);
}

.breadcrumb span {
    margin: 0 8px;
    color: var(--muted);
}

/* --- Product Detail Layout --- */
.product-detail {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    padding: 16px 0 64px;
}

/* --- Product Gallery --- */
.product-gallery .main-image {
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: 16px;
}

.product-gallery .main-image img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
}

.thumbnail-row {
    display: flex;
    gap: 12px;
}

.thumbnail {
    width: 80px;
    height: 80px;
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    cursor: pointer;
    transition: all 0.3s ease;
}

.thumbnail:hover,
.thumbnail.active {
    border-color: var(--accent);
}

.thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

/* --- Product Info --- */
.product-info .label {
    display: block;
    margin-bottom: 12px;
}

.product-info h1 {
    font-size: 36px;
    margin-bottom: 16px;
}

.product-info .rating-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
}

.product-info .rating-row .stars {
    color: var(--accent);
}

.product-info .rating-row span {
    color: var(--muted);
    font-size: 14px;
}

/* --- Price Block --- */
.price-block {
    margin-bottom: 32px;
}

.price-block .price {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 36px;
    color: var(--accent);
}

.price-block .old-price {
    font-size: 18px;
    color: var(--muted);
    text-decoration: line-through;
    margin-left: 12px;
}

/* --- Color Swatches --- */
.color-swatches {
    margin-bottom: 32px;
}

.color-swatches p {
    font-size: 14px;
    color: var(--muted);
    margin-bottom: 12px;
}

.swatches-row {
    display: flex;
    gap: 12px;
}

.swatch {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid var(--border);
    cursor: pointer;
    transition: all 0.3s ease;
}

.swatch:hover,
.swatch.active {
    border-color: var(--accent);
}

/* --- Quantity Selector --- */
.quantity-selector {
    display: flex;
    align-items: center;
    gap: 0;
    margin-bottom: 32px;
}

.quantity-selector p {
    font-size: 14px;
    color: var(--muted);
    margin-bottom: 12px;
}

.qty-controls {
    display: flex;
    align-items: center;
}

.qty-controls button {
    width: 40px;
    height: 40px;
    background-color: var(--elevated);
    border: 1px solid var(--border);
    color: var(--text);
    font-size: 18px;
    cursor: pointer;
    transition: all 0.3s ease;
}

.qty-controls button:first-child {
    border-radius: var(--radius) 0 0 var(--radius);
}

.qty-controls button:last-child {
    border-radius: 0 var(--radius) var(--radius) 0;
}

.qty-controls button:hover {
    background-color: var(--accent);
    color: #000;
    border-color: var(--accent);
}

.qty-controls .qty-value {
    width: 50px;
    height: 40px;
    background-color: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 500;
    font-size: 14px;
}

/* --- Action Buttons --- */
.product-actions {
    display: flex;
    gap: 16px;
}

.product-actions .btn {
    flex: 1;
}

/* --- Specs & Description --- */
.product-extra {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    padding: 64px 0;
    border-top: 1px solid var(--border);
}

.specs-section h3 {
    margin-bottom: 24px;
}

.specs-table {
    width: 100%;
    border-collapse: collapse;
}

.specs-table tr {
    border-bottom: 1px solid var(--border);
}

.specs-table td {
    padding: 12px 0;
    font-size: 14px;
}

.specs-table td:first-child {
    color: var(--muted);
    width: 40%;
}

.product-description h3 {
    margin-bottom: 16px;
}

.product-description p {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.8;
    margin-bottom: 16px;
}
</file>

<file path="css/profile.css">
/* ================================================
   ZEVO — Profile Page Styles
   Sidebar + orders table
   ================================================ */

/* --- Profile Header --- */
.profile-header {
    padding: 48px 0 0;
}

.profile-header h1 {
    font-size: 36px;
}

/* --- Profile Layout --- */
.profile-layout {
    display: grid;
