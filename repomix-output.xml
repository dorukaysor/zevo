<file path="css/components.css">
/* ================================================
   ZEVO — Component Styles
   Buttons, cards, badges, forms
   ================================================ */

/* --- Buttons --- */
.btn {
    display: inline-block;
    padding: 14px 32px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    border-radius: var(--radius);
    border: 2px solid transparent;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    text-decoration: none;
}

.btn-primary {
    background-color: var(--accent);
    color: #000;
    border-color: var(--accent);
}

.btn-primary:hover {
    background-color: #fbd94e;
    border-color: #fbd94e;
    color: #000;
}

.btn-outline {
    background-color: transparent;
    color: var(--accent);
    border-color: var(--accent);
}

.btn-outline:hover {
    background-color: var(--accent);
    color: #000;
}

.btn-ghost {
    background-color: transparent;
    color: var(--muted);
    border-color: transparent;
    padding: 14px 20px;
}

.btn-ghost:hover {
    background-color: var(--surface);
    color: var(--text);
}

/* --- Product Card --- */
.product-card {
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: all 0.3s ease;
}

.product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
}

.product-card-image {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    position: relative;
}

.product-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

/* badge inside card image */
.product-card-image .badge {
    position: absolute;
    top: 12px;
    left: 12px;
}

.product-card-body {
    padding: 16px;
}

.product-card-body .label {
    display: block;
    margin-bottom: 8px;
}

.product-card-body h3 {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 8px;
}

.product-card-body .price {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 18px;
    color: var(--accent);
}

.product-card-body .old-price {
    text-decoration: line-through;
    color: var(--muted);
    font-size: 14px;
    margin-left: 8px;
    font-weight: 400;
}

.product-card-body .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 12px;
}

/* --- Wishlist Button (on cards) --- */
.wishlist-btn {
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    font-size: 16px;
    transition: all 0.3s ease;
    padding: 4px;
}

.wishlist-btn:hover {
    color: var(--danger);
}

/* --- Badges / Tags --- */
.badge {
    display: inline-block;
    padding: 4px 12px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: 20px;
}

.badge-new {
    background-color: var(--accent);
    color: #000;
}

.badge-sale {
    background-color: var(--danger);
    color: #fff;
}

/* --- Star Rating --- */
.stars {
    color: var(--accent);
    font-size: 12px;
    letter-spacing: 2px;
}

/* --- Form Elements --- */
.form-group {
    margin-bottom: 20px;
}

.form-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
}

.form-input {
    width: 100%;
    padding: 12px 16px;
    background-color: var(--elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 14px;
    transition: all 0.3s ease;
}

.form-input:focus {
    outline: none;
    border-color: var(--accent);
}

textarea.form-input {
    resize: vertical;
    min-height: 120px;
}

select.form-input {
    appearance: none;
    cursor: pointer;
}

/* --- Checkbox / Radio --- */
.form-checkbox {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
    cursor: pointer;
    font-size: 14px;
    color: var(--text);
}

.form-checkbox input {
    accent-color: var(--accent);
    width: 16px;
    height: 16px;
}
</file>

